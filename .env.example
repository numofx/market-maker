# USDC/cNGN spot empty-book bootstrap via external anchor.
# This path is only used when MM_MARKET_SYMBOL=USDCcNGN-SPOT.
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_ENABLED=false
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_PROVIDER=cngn-price-oracle
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_BASE_URL=
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_API_KEY=
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_CHAIN_ID=8453
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_SELL_TOKEN=0x0000000000000000000000000000000000000000
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_BUY_TOKEN=0x0000000000000000000000000000000000000000
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_AMOUNT=1000000
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_TIMEOUT_MS=1500
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_MAX_AGE_SECONDS=30
MM_USDCCNGN_SPOT_EXTERNAL_ANCHOR_MAX_DEVIATION_BPS=500
